{
  "expo": {
    "name": "OLNs",
    "slug": "olns",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.olns.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "OLNs uses Bluetooth to connect with nearby devices on the mesh",
        "NSBluetoothPeripheralUsageDescription": "OLNs uses Bluetooth to connect with nearby devices on the mesh",
        "NSLocationWhenInUseUsageDescription": "Location is used for Bluetooth peer discovery",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral"
        ]
      }
    },
    "android": {
      "package": "com.olns.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-permissions",
        {
          "iosPermissions": [
            "Bluetooth"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "48cbcfac-3aae-4f5f-a0ef-287cb42e804e"
      }
    }
  }
}
